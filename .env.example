# ─────────────────────────────────────────────────────────────
# Cognix — Environment configuration (example)
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Web (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# API (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
POSTGRES_USER=cognix
POSTGRES_PASSWORD=cognix
POSTGRES_DB=cognix
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cognix:cognix@localhost:5432/cognix?schema=public

# Cache / queue (Redis)
REDIS_URL=redis://localhost:6379/0

# Auth
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_JWT_ISSUER=cognix
AUTH_JWT_AUDIENCE=cognix-app
AUTH_ACCESS_TOKEN_TTL=900
AUTH_REFRESH_TOKEN_TTL=1209600

# AI (Anthropic)
ANTHROPIC_API_KEY=
COGNIX_AI_DEFAULT_MODEL=claude-sonnet-5
